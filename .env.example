# Nakama Server Configuration Environment Variables

# [REQUIRED] Key used for administrative operations (uploading/deleting games/modpacks)
ADMIN_KEY=change-me-to-something-secure-admin

# [REQUIRED] Key used for querying and downloading games/modpacks
DOWNLOAD_KEY=change-me-to-something-secure-download

# [OPTIONAL] Port the server runs on (defaults to 8080)
PORT=8080

# [OPTIONAL] Maximum size allowed for uploaded files in bytes (defaults to 10GB = 10737418240)
MAX_UPLOAD_BYTES=10737418240
